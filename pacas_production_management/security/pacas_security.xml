<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <record id="module_category_pacas" model="ir.module.category">
        <field name="name">Producción de Pacas</field>
        <field name="sequence">50</field>
    </record>

    <record id="res_groups_privilege_pacas" model="res.groups.privilege">
        <field name="name">Producción de Pacas</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="module_category_pacas"/>
    </record>

    <record id="group_pacas_operator" model="res.groups">
        <field name="name">Operador</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_pacas"/>
    </record>

    <record id="group_pacas_supervisor" model="res.groups">
        <field name="name">Supervisor</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_pacas"/>
        <field name="implied_ids" eval="[(4, ref('group_pacas_operator'))]"/>
    </record>

    <record id="group_pacas_manager" model="res.groups">
        <field name="name">Gerente</field>
        <field name="sequence">30</field>
        <field name="privilege_id" ref="res_groups_privilege_pacas"/>
        <field name="implied_ids" eval="[(4, ref('group_pacas_supervisor'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</data>
</odoo>
