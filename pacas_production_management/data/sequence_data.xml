<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="seq_pacas_container" model="ir.sequence">
            <field name="name">Secuencia Contenedor</field>
            <field name="code">pacas.container</field>
            <field name="prefix">CONT-%(year)s-</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_pacas_classification_batch" model="ir.sequence">
            <field name="name">Secuencia Clasificación</field>
            <field name="code">pacas.classification.batch</field>
            <field name="prefix">CLAS-%(year)s-</field>
            <field name="padding">4</field>
        </record>
    </data>
</odoo>
