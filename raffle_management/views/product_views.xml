<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_raffle" model="ir.ui.view">
        <field name="name">product.template.form.raffle</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']" position="inside">
                <group string="Sorteo" invisible="not is_raffle_ticket">
                    <field name="is_raffle_ticket" readonly="1"/>
                    <field name="raffle_id" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
