<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ FORM VIEW ============ -->
    <record id="view_raffle_form" model="ir.ui.view">
        <field name="name">raffle.raffle.form</field>
        <field name="model">raffle.raffle</field>
        <field name="arch" type="xml">
            <form string="Sorteo">
                <header>
                    <button name="action_confirm" string="Confirmar Sorteo"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="raffle_management.group_raffle_manager"/>
                    <button name="action_open_draw_wizard" string="Ejecutar Sorteo"
                            type="object" class="btn-primary"
                            invisible="state not in ('completed', 'draw_pending')"
                            groups="raffle_management.group_raffle_manager"/>
                    <button name="action_mark_delivered" string="Marcar Entregado"
                            type="object" class="btn-primary"
                            invisible="state != 'finished'"
                            groups="raffle_management.group_raffle_manager"/>
                    <button name="action_cancel" string="Cancelar"
                            type="object"
                            invisible="state in ('delivered', 'cancelled')"
                            groups="raffle_management.group_raffle_manager"/>
                    <button name="action_reset_to_draft" string="Volver a Borrador"
                            type="object"
                            invisible="state != 'cancelled'"
                            groups="raffle_management.group_raffle_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,on_sale,completed,finished,delivered"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_tickets"
                                class="oe_stat_button" icon="fa-ticket">
                            <field name="sold_tickets_count" widget="statinfo" string="Tickets Vendidos"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Cancelado" bg_color="text-bg-danger"
                            invisible="state != 'cancelled'"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Producto">
                            <field name="product_id" readonly="state != 'draft'"/>
                            <field name="product_value" widget="monetary" readonly="state != 'draft'"/>
                            <field name="total_tickets" readonly="state != 'draft'"/>
                        </group>
                        <group string="Precio del Ticket">
                            <field name="suggested_ticket_price" widget="monetary"/>
                            <field name="ticket_price" widget="monetary" readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Sorteo">
                            <field name="draw_date"/>
                            <field name="winner_ticket_id" invisible="state not in ('finished', 'delivered')"/>
                            <field name="winner_partner_id" invisible="state not in ('finished', 'delivered')"/>
                            <field name="random_seed_sum" groups="base.group_no_one"/>
                        </group>
                        <group string="Configuración">
                            <field name="category_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="ticket_product_id" invisible="not ticket_product_id"/>
                            <field name="stock_location_id" invisible="not stock_location_id"/>
                        </group>
                    </group>
                    <group string="Progreso de Ventas">
                        <field name="progress" widget="progressbar"/>
                        <field name="available_tickets_count"/>
                        <field name="sold_tickets_count"/>
                    </group>
                    <notebook>
                        <page string="Tickets" name="tickets">
                            <field name="ticket_ids" readonly="1">
                                <list decoration-success="state == 'available'"
                                      decoration-danger="state == 'sold'"
                                      decoration-warning="state == 'winner'"
                                      decoration-muted="state == 'cancelled'">
                                    <field name="number"/>
                                    <field name="name"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'available'"
                                           decoration-danger="state == 'sold'"
                                           decoration-warning="state == 'winner'"
                                           decoration-muted="state == 'cancelled'"/>
                                    <field name="partner_id"/>
                                    <field name="purchase_date"/>
                                    <field name="can_cancel"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============ LIST VIEW ============ -->
    <record id="view_raffle_list" model="ir.ui.view">
        <field name="name">raffle.raffle.list</field>
        <field name="model">raffle.raffle</field>
        <field name="arch" type="xml">
            <list string="Sorteos"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'on_sale'"
                  decoration-warning="state in ('completed', 'draw_pending')"
                  decoration-danger="state == 'cancelled'"
                  decoration-muted="state == 'delivered'">
                <field name="name"/>
                <field name="product_id"/>
                <field name="product_value" widget="monetary"/>
                <field name="total_tickets"/>
                <field name="sold_tickets_count"/>
                <field name="ticket_price" widget="monetary"/>
                <field name="draw_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'on_sale'"
                       decoration-warning="state in ('completed', 'draw_pending')"
                       decoration-danger="state == 'cancelled'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ============ KANBAN VIEW ============ -->
    <record id="view_raffle_kanban" model="ir.ui.view">
        <field name="name">raffle.raffle.kanban</field>
        <field name="model">raffle.raffle</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state" quick_create="false">
                <templates>
                    <t t-name="card">
                        <div class="d-flex">
                            <field name="product_image" widget="image" class="me-2"
                                   options="{'img_class': 'rounded', 'size': [80, 80]}"/>
                            <div class="flex-grow-1">
                                <strong><field name="name"/></strong>
                                <div><field name="product_id"/></div>
                                <div class="text-muted">
                                    <field name="sold_tickets_count"/> / <field name="total_tickets"/> tickets
                                </div>
                                <field name="progress" widget="progressbar"/>
                                <div>
                                    <field name="ticket_price" widget="monetary"/>
                                    <field name="currency_id" invisible="1"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============ SEARCH VIEW ============ -->
    <record id="view_raffle_search" model="ir.ui.view">
        <field name="name">raffle.raffle.search</field>
        <field name="model">raffle.raffle</field>
        <field name="arch" type="xml">
            <search string="Buscar Sorteos">
                <field name="name"/>
                <field name="product_id"/>
                <field name="winner_partner_id"/>
                <separator/>
                <filter string="En Venta" name="on_sale" domain="[('state', '=', 'on_sale')]"/>
                <filter string="Completados" name="completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Finalizados" name="finished" domain="[('state', '=', 'finished')]"/>
                <separator/>
                <group>
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Producto" name="group_product" context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============ ACTION ============ -->
    <record id="action_raffle_raffle" model="ir.actions.act_window">
        <field name="name">Sorteos</field>
        <field name="res_model">raffle.raffle</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_raffle_search"/>
        <field name="context">{'search_default_on_sale': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Crea tu primer sorteo!
            </p>
            <p>
                Selecciona un producto con stock y define la cantidad de tickets para comenzar.
            </p>
        </field>
    </record>
</odoo>
