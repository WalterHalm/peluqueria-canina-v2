<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_real_estate" model="ir.ui.view">
        <field name="name">res.config.settings.real.estate</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Real Estate" string="Real Estate" name="real_estate">
                    <block title="WhatsApp y Redes Sociales" id="real_estate_social_settings">
                        <setting string="WhatsApp" help="Número en formato internacional (ej: 573001234567)">
                            <field name="whatsapp_number" placeholder="573001234567"/>
                        </setting>
                        <setting string="Facebook">
                            <field name="facebook_url" placeholder="https://facebook.com/..."/>
                        </setting>
                        <setting string="Instagram">
                            <field name="instagram_url" placeholder="https://instagram.com/..."/>
                        </setting>
                        <setting string="TikTok">
                            <field name="tiktok_url" placeholder="https://tiktok.com/@..."/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
