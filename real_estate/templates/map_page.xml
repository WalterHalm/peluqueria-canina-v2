<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="map_page" name="Mapa de Propiedades">
        <t t-call="website.layout">
            <div id="wrap" class="re-page">
                <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

                <!-- ── HEADER BÚSQUEDA ── -->
                <div class="re-search-header" id="re_search_header">
                    <div class="re-search-bar">
                        <div class="re-search-field re-search-field--place">
                            <label>Lugar</label>
                            <input type="text" id="re_search_place" placeholder="¿A dónde vas?"/>
                        </div>
                        <div class="re-search-divider"/>
                        <div class="re-search-field re-search-field--dates">
                            <label>Llegada</label>
                            <input type="date" id="re_date_in"/>
                        </div>
                        <div class="re-search-divider"/>
                        <div class="re-search-field re-search-field--dates">
                            <label>Salida</label>
                            <input type="date" id="re_date_out"/>
                        </div>
                        <div class="re-search-divider"/>
                        <div class="re-search-field re-search-field--guests">
                            <label>Viajeros</label>
                            <input type="number" id="re_guests" min="1" max="20" placeholder="1"/>
                        </div>
                        <button class="re-search-btn" id="re_search_btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- ── BARRA RESULTADOS + FILTROS ── -->
                <div class="re-results-bar" id="re_results_bar">
                    <div class="re-results-info">
                        <span id="re_prop_count">Cargando...</span>
                    </div>
                    <div class="re-results-actions">
                        <!-- Toggle lista/mapa (solo móvil) -->
                        <div class="re-view-toggle" id="re_view_toggle">
                            <button class="re-view-btn re-view-btn--active" data-view="list" title="Lista">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
                                    <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
                                    <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
                                </svg>
                            </button>
                            <button class="re-view-btn" data-view="map" title="Mapa">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/>
                                    <line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>
                                </svg>
                            </button>
                        </div>
                        <button class="re-filter-toggle" id="re_filter_toggle">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/>
                            </svg>
                            Filtros
                            <span class="re-filter-badge" id="re_filter_badge" style="display:none">0</span>
                        </button>
                        <button id="re_clear_filters" class="re-clear-btn" style="display:none">
                            ✕ Limpiar
                        </button>
                    </div>
                </div>

                <!-- ── LAYOUT PRINCIPAL ── -->
                <div class="re-map-layout">

                    <!-- Lista 60% -->
                    <div class="re-prop-list" id="re_prop_list">
                        <div id="re_prop_cards"/>
                    </div>

                    <!-- Mapa 40% sticky -->
                    <div class="re-map-sticky">
                        <div id="re_map" class="re-map-container"/>
                    </div>

                </div>

                <!-- ── MODAL FILTROS ── -->
                <div class="re-modal-overlay" id="re_modal_overlay">
                    <div class="re-modal">
                        <div class="re-modal-header">
                            <button class="re-modal-close" id="re_modal_close">✕</button>
                            <h3>Filtros</h3>
                            <button class="re-modal-clear" id="re_modal_clear">Borrar todo</button>
                        </div>
                        <div class="re-modal-body">

                            <!-- Tipo de propiedad -->
                            <t t-if="tipos">
                                <div class="re-modal-section">
                                    <h4>Tipo de propiedad</h4>
                                    <div class="re-modal-chips" data-group="tipo">
                                        <t t-foreach="tipos" t-as="v">
                                            <button class="re-chip re-filter-btn" t-att-data-value="v">
                                                <t t-out="v"/>
                                            </button>
                                        </t>
                                    </div>
                                </div>
                                <div class="re-modal-divider"/>
                            </t>

                            <!-- Habitaciones -->
                            <t t-if="habitaciones_opts">
                                <div class="re-modal-section">
                                    <h4>Habitaciones</h4>
                                    <div class="re-modal-chips" data-group="habitaciones">
                                        <t t-foreach="habitaciones_opts" t-as="v">
                                            <button class="re-chip re-filter-btn" t-att-data-value="v">
                                                <t t-out="v"/>
                                            </button>
                                        </t>
                                    </div>
                                </div>
                                <div class="re-modal-divider"/>
                            </t>

                            <!-- Zona -->
                            <t t-if="zones">
                                <div class="re-modal-section">
                                    <h4>Zona</h4>
                                    <div class="re-modal-chips" data-group="zona">
                                        <t t-foreach="zones" t-as="v">
                                            <button class="re-chip re-filter-btn" t-att-data-value="v">
                                                <t t-out="v"/>
                                            </button>
                                        </t>
                                    </div>
                                </div>
                            </t>

                        </div>
                        <div class="re-modal-footer">
                            <button class="re-modal-apply" id="re_modal_apply">
                                Ver propiedades
                            </button>
                        </div>
                    </div>
                </div>

            </div>

            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"/>
            <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" type="text/css"/>
            <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" type="text/css"/>
            <script src="/real_estate/static/src/js/map_page.js"/>
        </t>
    </template>
</odoo>
