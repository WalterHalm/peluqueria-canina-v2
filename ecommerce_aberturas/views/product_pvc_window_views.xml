<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="view_product_template_form_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']" position="after">
                <page string="Ventana PVC" invisible="not is_pvc_window">
                    <group>
                        <group string="Identificación">
                            <field name="is_pvc_window"/>
                        </group>
                        <group string="Medidas">
                            <field name="width"/>
                            <field name="height"/>
                            <field name="custom_size"/>
                        </group>
                    </group>
                    <group>
                        <group string="Características Técnicas">
                            <field name="thermal_insulation"/>
                            <field name="acoustic_insulation"/>
                            <field name="security_level"/>
                        </group>
                        <group string="Precios Especiales">
                            <field name="price_distributor"/>
                            <field name="min_quantity_distributor"/>
                        </group>
                    </group>
                    <group string="Ficha Técnica">
                        <field name="technical_sheet" filename="technical_sheet_filename"/>
                        <field name="technical_sheet_filename" invisible="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_search_inherit" model="ir.ui.view">
        <field name="name">product.template.search.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
                <separator/>
                <filter string="Ventanas PVC" name="pvc_windows" domain="[('is_pvc_window', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <record id="action_pvc_windows" model="ir.actions.act_window">
        <field name="name">Ventanas PVC</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_pvc_window', '=', True)]</field>
        <field name="context">{'default_is_pvc_window': True, 'default_detailed_type': 'product'}</field>
    </record>

</odoo>
