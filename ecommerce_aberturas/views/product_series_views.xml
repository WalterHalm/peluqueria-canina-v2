<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="view_product_series_tree" model="ir.ui.view">
        <field name="name">product.series.list</field>
        <field name="model">product.series</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="quality_level"/>
                <field name="product_count"/>
            </list>
        </field>
    </record>

    <record id="view_product_series_search" model="ir.ui.view">
        <field name="name">product.series.search</field>
        <field name="model">product.series</field>
        <field name="arch" type="xml">
            <search string="Buscar Series">
                <field name="name"/>
                <field name="code"/>
                <separator/>
                <filter string="Activas" name="filter_active" domain="[('active', '=', True)]"/>
                <group>
                    <filter string="Nivel de Calidad" name="group_quality" context="{'group_by': 'quality_level'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_product_series_form" model="ir.ui.view">
        <field name="name">product.series.form</field>
        <field name="model">product.series</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_products" type="object" class="oe_stat_button" icon="fa-cube">
                            <field name="product_count" widget="statinfo" string="Productos"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre de la Serie"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="quality_level"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" widget="html"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_series" model="ir.actions.act_window">
        <field name="name">Series de Ventanas</field>
        <field name="res_model">product.series</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_product_series_search"/>
    </record>

</odoo>
